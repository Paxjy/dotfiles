{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "qwen3-coder-30B": {
          "name": "Qwen3-Coder A3B-30B",
          "limit": {
            "context": 64000,
            "output": 16384
          }
        },
        "gpt-oss": {
          "name": "Gpt-oss",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "glm-4.7-flash": {
          "name": "Glm-4.7 flash",
          "limit": {
            "context": 80000,
            "output": 16384
          }
        },
        "qwen3-coder-next": {
          "name": "Qwen3 Coder Next",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },

        "devstral-small-2": {
          "name": "Devstral Small 2",
          "limit": {
            "context": 32000,
            "output": 16384
          }
        },

        "qwen3.5-27b": {
          "name": "Qwen3.5 27B",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        
        "qwen3.5-35b-3a": {
          "name": "qwen3.5-35b-3a",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        }
      }
    }
  }
}