            "context": 128000,
            "output": 16384
          }
        },
        "glm-4.7-flash": {
          "name": "Glm-4.7 flash",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "qwen3-coder-next-q3": {
          "name": "Qwen3-Coder-Next-Q3",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        },
        "qwen3-coder-next-q2": {
          "name": "Qwen3-Coder-Next-Q2",
          "limit": {
            "context": 128000,
            "output": 16384
          }
        }

      }
    }
  }
}